# ============================================
# BASE DE AUTOMAÇÕES - VARIÁVEIS DE AMBIENTE
# ============================================

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-publica-aqui
SUPABASE_SECRET=sua-chave-secreta-aqui

# Chatwoot
CHATWOOT_API=https://seu-chatwoot.com
CHATWOOT_TOKEN=seu-token-api-chatwoot
CHATWOOT_ACCOUNT_ID=1

# API de Automações
PORT=3001
API_TOKEN=seu-token-secreto-api

# Sincronização
SYNC_INTERVAL=3600000  # 1 hora em ms
SYNC_AUTO=true

# Logs
LOG_LEVEL=info
LOG_FILE=logs/automacoes.log

# Feature Flags
FEATURE_SMART_SELECTOR=true
FEATURE_AUTO_RULES=true
FEATURE_ANALYTICS=true
FEATURE_WEBHOOKS=true
