# ── Supabase ─────────────────────────────────────────────────
# URL do projeto e SERVICE ROLE KEY (chave admin que bypassa RLS).
# Use service_role só no backend/bot — nunca exponha no frontend.
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=SUA_SERVICE_ROLE_KEY_AQUI

# ── Chatwoot — disparo automático ────────────────────────────
CHATWOOT_URL=https://SEU-CHATWOOT.exemplo
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_TOKEN=SEU_TOKEN_CHATWOOT
CHATWOOT_INBOX_ID=1

# (opcional) Fallback de mensagem livre se não houver template
# vinculado à etapa "Lead Novo" em crm_stage_templates. Só é
# entregue se a inbox estiver dentro da janela de 24h do WhatsApp.
# CHATWOOT_MENSAGEM=Oi! Aqui é o time da Zeve…

# (opcional) Desliga o disparo automático sem mexer no código.
# Padrão: ligado. Defina como "false" para desligar.
# CHATWOOT_AUTO_DISPARO=false
